[
  {
    "rule_id": "CR001",
    "rule_name": "禁止确定性承诺",
    "type": "forbidden_phrase",
    "pattern": "一定\\s*(能|可以|会|能够)\\s*(批|过|通过|下款|放款|批准)",
    "severity": "critical",
    "action": "block",
    "description": "禁止使用确定性承诺用语，违反监管规定。违规示例：'您一定可以批下来'、'肯定能通过'。",
    "source": "金融监管总局合规指引"
  },
  {
    "rule_id": "CR002",
